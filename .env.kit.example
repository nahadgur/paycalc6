# --- Kit checkout configuration (copy into .env.local) ---

# Which provider handles /kit checkout: "intasend" (STK push, recommended) or "pesapal" (hosted redirect)
PAYMENT_PROVIDER=intasend

# Price in KES (server-side source of truth)
KIT_PRICE_KES=299

# Public site URL (used in download links + Pesapal callback)
SITE_URL=https://www.payecalculator.co.ke

# Secret for signing download tokens. Generate with: openssl rand -hex 32
KIT_DOWNLOAD_SECRET=

# --- IntaSend (https://intasend.com -> API keys) ---
# Sandbox base: https://sandbox.intasend.com   Live base: https://payment.intasend.com
INTASEND_BASE_URL=https://payment.intasend.com
INTASEND_SECRET_KEY=
# Set the same value in IntaSend dashboard -> Webhooks (challenge) and point the
# webhook to https://www.payecalculator.co.ke/api/kit/webhook
INTASEND_WEBHOOK_CHALLENGE=

# --- Pesapal API 3.0 (only if PAYMENT_PROVIDER=pesapal) ---
# Sandbox base: https://cybqa.pesapal.com/pesapalv3   Live: https://pay.pesapal.com/v3
PESAPAL_BASE_URL=https://pay.pesapal.com/v3
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
# One-time: register your IPN URL (see docs/KIT-CHECKOUT.md) and paste the returned ipn_id
PESAPAL_IPN_ID=

# --- Delivery email (Resend, https://resend.com) ---
# Leave empty to skip emails (success-page download still works)
RESEND_API_KEY=
KIT_FROM_EMAIL="PAYE Calculator Kenya <kit@payecalculator.co.ke>"
